      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "habits_completed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "habit": {
      "type": "string"
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
