# Frontend app
# Must include /api because the frontend calls endpoints like /auth/login under the API base URL.
VITE_API_BASE_URL=https://se7en-fit-api.onrender.com/api
VITE_API_TIMEOUT_MS=15000

# Optional, only needed when Google login is enabled.
VITE_GOOGLE_CLIENT_ID=

# Razorpay checkout key ID for test/live mode.
# Use only the key_id here. Never put key_secret in the frontend.
VITE_RAZORPAY_KEY_ID=
